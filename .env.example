# ── Backend ──────────────────────────────────────────────────
# Local (example: postgres / admin — run `npm run db:setup` in backend after DATABASE_URL is set)
DATABASE_URL="postgresql://postgres:admin@localhost:5432/fireverse_db"
JWT_SECRET="your-super-secret-jwt-key-min-32-chars-here"
JWT_REFRESH_SECRET="your-refresh-secret-key-min-32-chars-here"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"
PORT=3001
NODE_ENV=development
FRONTEND_URL="http://localhost:5173"

# File uploads
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE_MB=10

# Email (stub)
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_USER="noreply@fireverse.gov.in"
SMTP_PASS="your-smtp-password"

# SMS (stub — Twilio)
TWILIO_ACCOUNT_SID="ACxxxxxxxx"
TWILIO_AUTH_TOKEN="your-twilio-token"
TWILIO_FROM="+1234567890"

# ── Frontend (Vite) ───────────────────────────────────────────
VITE_API_BASE_URL="http://localhost:3001/api"
VITE_APP_NAME="Fireverse"

# ── Railway (set in dashboard → Variables, do not commit secrets) ──
# DATABASE_URL      → Reference variable from the Postgres plugin (Connect)
# DATABASE_SSL=true → If DB connections fail or hang, try this (TLS for pg pool)
# FRONTEND_URL      → https://<your-app>.up.railway.app (public URL of this service)
# JWT_SECRET        → long random string (32+ chars)
# JWT_REFRESH_SECRET→ long random string (32+ chars)
# NODE_ENV=production
# (Monolith root Dockerfile bakes VITE_API_BASE_URL=/api — same-origin API; no extra Vite env needed.)
