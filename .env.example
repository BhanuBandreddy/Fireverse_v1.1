# ── Backend ──────────────────────────────────────────────────
DATABASE_URL="postgresql://fireverse:fireverse123@localhost:5432/fireverse_db"
JWT_SECRET="your-super-secret-jwt-key-min-32-chars-here"
JWT_REFRESH_SECRET="your-refresh-secret-key-min-32-chars-here"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"
PORT=3001
NODE_ENV=development
FRONTEND_URL="http://localhost:5173"

# File uploads
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE_MB=10

# Email (stub)
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_USER="noreply@fireverse.gov.in"
SMTP_PASS="your-smtp-password"

# SMS (stub — Twilio)
TWILIO_ACCOUNT_SID="ACxxxxxxxx"
TWILIO_AUTH_TOKEN="your-twilio-token"
TWILIO_FROM="+1234567890"

# ── Frontend (Vite) ───────────────────────────────────────────
VITE_API_BASE_URL="http://localhost:3001/api"
VITE_APP_NAME="Fireverse"
